# Skopiuj jako .env.production na serwerze (NIE commituj do gita)
# Baked in przez Vite podczas: npm run build

# Pełny URL backendu — używany przez frontend (brak trailing slash)
# Jeśli nginx proxy /api na tym samym domenie, zostaw pusty string ""
# Jeśli backend na osobnym porcie/domenie, podaj pełny URL:
VITE_API_BASE_URL=https://twoja-domena.com
