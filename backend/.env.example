# Server
PORT=3001
NODE_ENV=production

# JWT Secrets — generate with: openssl rand -hex 64
JWT_SECRET=change-me-use-openssl-rand-hex-64
JWT_REFRESH_SECRET=change-me-use-openssl-rand-hex-64

# CSRF double-submit cookie secret — generate with: openssl rand -hex 32
CSRF_SECRET=change-me-use-openssl-rand-hex-32

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# Database path (relative to backend root)
DB_PATH=./securedesk.db

# Admin secret for /cooldown panel (no JWT auth — keep strong in production)
ADMIN_SECRET=change-me-use-openssl-rand-hex-32
